---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="bg-gradient-to-br from-[#1e3a5f] to-[#2d5a8e] text-white py-24 px-4">
  <div class="max-w-5xl mx-auto text-center">
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight">
      Your Path to Medical School Starts Here
    </h1>
    <p class="text-lg md:text-xl text-gray-300 mb-10 max-w-3xl mx-auto leading-relaxed">
      Expert MCAT preparation, admissions consulting, and academic guidance for aspiring physicians across Canada and beyond
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href={`${base}/mcat-prep`}
        class="inline-block bg-[#0d9488] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#0f766e] transition-colors duration-200"
      >
        Explore MCAT Prep
      </a>
      <a
        href={`${base}/sample-exam`}
        class="inline-block border-2 border-white text-white font-semibold px-8 py-3 rounded-lg hover:bg-white hover:text-[#1e3a5f] transition-colors duration-200"
      >
        Take Sample Exam
      </a>
    </div>

    <!-- Stats Bar -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16">
      <div>
        <span class="block text-3xl font-bold">98%</span>
        <span class="text-sm text-gray-300">Acceptance Rate</span>
      </div>
      <div class="hidden sm:block w-px h-10 bg-white/30"></div>
      <div>
        <span class="block text-3xl font-bold">1,000+</span>
        <span class="text-sm text-gray-300">Students Guided</span>
      </div>
      <div class="hidden sm:block w-px h-10 bg-white/30"></div>
      <div>
        <span class="block text-3xl font-bold">40+</span>
        <span class="text-sm text-gray-300">Countries</span>
      </div>
    </div>
  </div>
</section>
