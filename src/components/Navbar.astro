---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;

const navLinks = [
  { label: 'Home', href: '/' },
  { label: 'MCAT Prep', href: '/mcat-prep' },
  { label: 'Medical Admissions', href: '/medical-admissions' },
  { label: 'Sample Exam', href: '/sample-exam' },
  { label: 'University Admissions', href: '/university-admissions' },
  { label: 'Immigration', href: '/immigration' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
];

function isActive(href: string): boolean {
  const fullHref = href === '/' ? base + '/' : base + href;
  // Normalize: remove trailing slashes for comparison
  const normalizedCurrent = currentPath.replace(/\/$/, '') || '/';
  const normalizedHref = fullHref.replace(/\/$/, '') || '/';
  return normalizedCurrent === normalizedHref;
}
---

<nav class="sticky top-0 z-50 bg-[#1e3a5f] shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Brand -->
      <a href={`${base}/`} class="text-white font-bold text-xl tracking-tight">
        SKI Education
      </a>

      <!-- Desktop nav links -->
      <div class="hidden lg:flex items-center space-x-1">
        {navLinks.map((link) => (
          <a
            href={link.href === '/' ? `${base}/` : `${base}${link.href}`}
            class:list={[
              'px-3 py-2 rounded text-sm font-medium transition-colors duration-200',
              isActive(link.href)
                ? 'text-[#0d9488] bg-white/10'
                : 'text-white hover:text-[#0d9488] hover:bg-white/5',
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile hamburger button -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="lg:hidden inline-flex items-center justify-center p-2 rounded text-white hover:text-[#0d9488] hover:bg-white/10 transition-colors duration-200"
        aria-expanded="false"
        aria-label="Toggle navigation menu"
      >
        <!-- Hamburger icon -->
        <svg id="hamburger-icon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <!-- Close icon (hidden by default) -->
        <svg id="close-icon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-[#1e3a5f] border-t border-white/10">
    <div class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <a
          href={link.href === '/' ? `${base}/` : `${base}${link.href}`}
          class:list={[
            'block px-3 py-2 rounded text-base font-medium transition-colors duration-200',
            isActive(link.href)
              ? 'text-[#0d9488] bg-white/10'
              : 'text-white hover:text-[#0d9488] hover:bg-white/5',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    menu?.classList.toggle('hidden');
    hamburgerIcon?.classList.toggle('hidden');
    closeIcon?.classList.toggle('hidden');
  });
</script>
