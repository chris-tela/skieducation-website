---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<div class="bg-white rounded-xl shadow-md hover:shadow-xl hover:-translate-y-1 transition-all duration-300 p-6 flex flex-col">
  <div class="text-5xl mb-4">{icon}</div>
  <h3 class="text-xl font-bold text-[#1e3a5f] mb-2">{title}</h3>
  <p class="text-gray-600 mb-4 flex-grow">{description}</p>
  <a href={href} class="text-[#0d9488] font-semibold hover:text-[#0f766e] transition-colors duration-200">
    Learn More &rarr;
  </a>
</div>
