---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<BaseLayout title="Medical School Admissions Consulting" description="Expert guidance for your journey from pre-med to medical school — Canadian, American, and Caribbean programs.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-[#1e3a5f] to-[#162d4a] py-20 px-4 text-center text-white">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Medical School Admissions Consulting</h1>
      <p class="text-lg md:text-xl opacity-90 mb-8 max-w-3xl mx-auto">Expert guidance for your journey from pre-med to medical school — whether through Canadian, American, or Caribbean programs</p>
      <a href="mailto:ski.inc100@gmail.com?subject=Medical%20Admissions%20Consultation" class="inline-block bg-[#0d9488] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#0b7f74] transition-colors">Book a Consultation</a>
    </div>
  </section>

  <!-- Two Pathway Cards -->
  <section class="py-16 px-4 max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center text-[#1e3a5f] mb-4">Choose Your Pathway</h2>
    <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">Two proven routes to becoming a physician — we guide you through both</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <!-- Traditional Pathway -->
      <div class="border border-gray-200 rounded-xl p-8 hover:shadow-lg transition-shadow">
        <div class="text-4xl mb-4">&#x1F1E8;&#x1F1E6;</div>
        <h3 class="text-xl font-bold text-[#1e3a5f] mb-4">Traditional Pathway</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>For students targeting Canadian or US medical schools</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>Competitive GPA and MCAT required</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>Application strategy and school selection</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>Personal statement and interview coaching</span>
          </li>
        </ul>
      </div>
      <!-- Caribbean Pathway -->
      <div class="border border-gray-200 rounded-xl p-8 hover:shadow-lg transition-shadow">
        <div class="text-4xl mb-4">&#x1F334;</div>
        <h3 class="text-xl font-bold text-[#1e3a5f] mb-4">Caribbean Pathway</h3>
        <ul class="space-y-3 text-gray-700">
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>Alternative route for aspiring physicians</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>SKI represents one of the best Caribbean medical schools</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>USMLE preparation included</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#0d9488] font-bold mt-0.5">&#10003;</span>
            <span>Clinical rotations and residency placement in North America</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- What We Offer -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#1e3a5f] mb-4">What We Offer</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">Comprehensive support at every stage of the admissions process</p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 bg-[#1e3a5f] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-xl">&#128196;</span>
          </div>
          <h3 class="text-lg font-bold text-[#1e3a5f] mb-2">Application Review</h3>
          <p class="text-gray-600 text-sm">Comprehensive review of your medical school application package</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 bg-[#1e3a5f] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-xl">&#9997;&#65039;</span>
          </div>
          <h3 class="text-lg font-bold text-[#1e3a5f] mb-2">Personal Statement Coaching</h3>
          <p class="text-gray-600 text-sm">Craft a compelling narrative that stands out</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 bg-[#1e3a5f] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-xl">&#128172;</span>
          </div>
          <h3 class="text-lg font-bold text-[#1e3a5f] mb-2">Interview Preparation</h3>
          <p class="text-gray-600 text-sm">Mock interviews and strategies for MMI and panel formats</p>
        </div>
        <div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow text-center">
          <div class="w-14 h-14 bg-[#1e3a5f] rounded-full flex items-center justify-center mx-auto mb-4">
            <span class="text-white text-xl">&#127919;</span>
          </div>
          <h3 class="text-lg font-bold text-[#1e3a5f] mb-2">School Selection Strategy</h3>
          <p class="text-gray-600 text-sm">Data-driven guidance on where to apply based on your profile</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Clinical Training & Research -->
  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-[#1e3a5f] mb-4">Clinical Training & Research</h2>
      <p class="text-lg text-gray-600 mb-6">Access clinical training and research opportunities across North America</p>
      <div class="bg-gray-50 rounded-xl p-8 md:p-10 text-left">
        <p class="text-gray-700 mb-4">Through our partnership with <strong>AMOpportunities</strong>, students gain access to hands-on clinical rotations and research certificate programs at leading healthcare institutions across North America.</p>
        <p class="text-gray-700 mb-6">Whether you need clinical experience to strengthen your application or are preparing for residency placement, these opportunities provide invaluable real-world medical training and mentorship.</p>
        <div class="text-center">
          <a href="https://www.amopportunities.org/" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#1e3a5f] text-white font-semibold px-8 py-3 rounded-lg hover:bg-[#162d4a] transition-colors">Explore Opportunities &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Your Journey (5-step timeline) -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="max-w-6xl mx-auto">
      <h2 class="text-3xl font-bold text-center text-[#1e3a5f] mb-4">Your Journey</h2>
      <p class="text-center text-gray-600 mb-12 max-w-2xl mx-auto">A clear path from first consultation to medical school acceptance</p>

      <!-- Desktop timeline -->
      <div class="hidden md:block">
        <div class="flex items-start justify-between relative">
          <!-- Connecting line -->
          <div class="absolute top-6 left-[10%] right-[10%] h-0.5 bg-[#0d9488]"></div>

          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-12 h-12 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">1</div>
            <h3 class="font-bold text-[#1e3a5f] mb-1 text-sm">Initial Consultation</h3>
            <p class="text-gray-600 text-xs px-2">Assess your goals, GPA, MCAT readiness</p>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-12 h-12 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">2</div>
            <h3 class="font-bold text-[#1e3a5f] mb-1 text-sm">Strategy Development</h3>
            <p class="text-gray-600 text-xs px-2">Create personalized application roadmap</p>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-12 h-12 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">3</div>
            <h3 class="font-bold text-[#1e3a5f] mb-1 text-sm">Application Support</h3>
            <p class="text-gray-600 text-xs px-2">Guide you through every application component</p>
          </div>

          <!-- Step 4 -->
          <div class="flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-12 h-12 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">4</div>
            <h3 class="font-bold text-[#1e3a5f] mb-1 text-sm">Interview Coaching</h3>
            <p class="text-gray-600 text-xs px-2">Practice and prepare for admissions interviews</p>
          </div>

          <!-- Step 5 -->
          <div class="flex flex-col items-center text-center w-1/5 relative z-10">
            <div class="w-12 h-12 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold text-lg mb-3">5</div>
            <h3 class="font-bold text-[#1e3a5f] mb-1 text-sm">Acceptance & Beyond</h3>
            <p class="text-gray-600 text-xs px-2">Support through enrollment and transition</p>
          </div>
        </div>
      </div>

      <!-- Mobile timeline (vertical) -->
      <div class="md:hidden space-y-6">
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold shrink-0">1</div>
            <div class="w-0.5 h-full bg-[#0d9488] mt-2"></div>
          </div>
          <div class="pb-4">
            <h3 class="font-bold text-[#1e3a5f]">Initial Consultation</h3>
            <p class="text-gray-600 text-sm">Assess your goals, GPA, MCAT readiness</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold shrink-0">2</div>
            <div class="w-0.5 h-full bg-[#0d9488] mt-2"></div>
          </div>
          <div class="pb-4">
            <h3 class="font-bold text-[#1e3a5f]">Strategy Development</h3>
            <p class="text-gray-600 text-sm">Create personalized application roadmap</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold shrink-0">3</div>
            <div class="w-0.5 h-full bg-[#0d9488] mt-2"></div>
          </div>
          <div class="pb-4">
            <h3 class="font-bold text-[#1e3a5f]">Application Support</h3>
            <p class="text-gray-600 text-sm">Guide you through every application component</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold shrink-0">4</div>
            <div class="w-0.5 h-full bg-[#0d9488] mt-2"></div>
          </div>
          <div class="pb-4">
            <h3 class="font-bold text-[#1e3a5f]">Interview Coaching</h3>
            <p class="text-gray-600 text-sm">Practice and prepare for admissions interviews</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <div class="flex flex-col items-center">
            <div class="w-10 h-10 bg-[#0d9488] text-white rounded-full flex items-center justify-center font-bold shrink-0">5</div>
          </div>
          <div>
            <h3 class="font-bold text-[#1e3a5f]">Acceptance & Beyond</h3>
            <p class="text-gray-600 text-sm">Support through enrollment and transition</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-[#0d9488] py-16 px-4 text-center text-white">
    <h2 class="text-3xl font-bold mb-4">Take the First Step Toward Medical School</h2>
    <p class="text-lg mb-8 max-w-2xl mx-auto opacity-90">Connect with our admissions experts and start building your path to becoming a physician.</p>
    <a href="mailto:ski.inc100@gmail.com?subject=Medical%20Admissions%20Consultation" class="inline-block bg-white text-[#0d9488] font-semibold px-8 py-3 rounded-lg hover:bg-gray-100 transition-colors">Book a Consultation</a>
  </section>

</BaseLayout>
